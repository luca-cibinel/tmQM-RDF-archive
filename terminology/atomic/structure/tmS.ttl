@prefix tmB: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/bond/> .
@prefix tmA: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/atom/> .
@prefix tmS: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/structure/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

tmS:b
	rdfs:domain tmA:Atom ;
	rdfs:range tmB:AtomicBond ;
	rdfs:label "Atomic bond"^^xmls:string ;
	rdfs:comment "Indicates that an atom participates in a chemical bond represented by the object."^^xmls:string ;
.