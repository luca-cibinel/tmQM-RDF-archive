@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tmB: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/bond/> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

tmB:AtomicBond
	rdf:type rdfs:Class ;
	rdfs:label "Chemical bond (atomic level)"^^xmls:string ;
	rdfs:comment "This class represents a chemical bond between two atoms."^^xmls:string ;
.

tmB:NBOType
	rdf:type rdfs:Class ;
	rdfs:label "NBO type"^^xmls:string ;
	rdfs:comment "This class represents a possible NBO type, intended as a label that can be assigned to a chemical bond."^^xmls:string ;
.