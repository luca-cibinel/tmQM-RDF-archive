@prefix ms: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/misc/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tmBp: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/bond/property/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

tmBp:bond_energy_min_max_difference
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Bonding orbitals - min-max difference"^^xmls:string ;
	rdfs:comment "Energy difference between lowest- and highest-energy bonding orbitals"^^xmls:string ;
.

tmBp:bond_max_energy
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Bonding orbitals - max energy"^^xmls:string ;
	rdfs:comment "Highest energy of bonding orbitals"^^xmls:string ;
.

tmBp:antibond_min_d_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Antibonding orbitals - min d occupation"^^xmls:string ;
	rdfs:comment "Minimum d occupation of antibonding orbitals"^^xmls:string ;
.

tmBp:bond_max_p_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Bonding orbitals - max p occupation"^^xmls:string ;
	rdfs:comment "Maximum p occupation of bonding orbitals"^^xmls:string ;
.

tmBp:n_nbn
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Number of antibonding orbitals"^^xmls:string ;
	rdfs:comment "Number of antibonding orbitals for bond"^^xmls:string ;
.

tmBp:antibond_min_s_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Antibonding orbitals - min s occupation"^^xmls:string ;
	rdfs:comment "Minimum s occupation of antibonding orbitals"^^xmls:string ;
.

tmBp:bond_max_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Antibonding orbitals - max occupation"^^xmls:string ;
	rdfs:comment "Maximum overall occupation of bonding orbitals"^^xmls:string ;
.

tmBp:bond_distance
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Bond distance"^^xmls:string ;
	rdfs:comment "Bond distance, in Å"^^xmls:string ;
.

tmBp:bond_max_d_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Bonding orbitals - max d occupation"^^xmls:string ;
	rdfs:comment "Maximum d occupation of bonding orbitals"^^xmls:string ;
.

tmBp:antibond_min_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Antibonding orbitals - min occupation"^^xmls:string ;
	rdfs:comment "Minimum overall occupation of antibonding orbitals"^^xmls:string ;
.

tmBp:n_bn
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Number of bonding orbitals"^^xmls:string ;
	rdfs:comment "Number of bonding orbitals for bond"^^xmls:string ;
.

tmBp:wiberg_bond_order
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Wiberg bond order"^^xmls:string ;
	rdfs:comment "Wiberg bond order"^^xmls:string ;
.

tmBp:nbo_type
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "NBO type"^^xmls:string ;
	rdfs:comment "NBO type defining the bond"^^xmls:string ;
.

tmBp:bond_max_s_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Bonding orbitals - max s occupation"^^xmls:string ;
	rdfs:comment "Maximum s occupation of bonding orbitals"^^xmls:string ;
.

tmBp:antibond_min_energy
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Antibonding orbitals - min energy"^^xmls:string ;
	rdfs:comment "Minimum energy of antibonding orbitals"^^xmls:string ;
.

tmBp:antibond_min_p_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Antibonding orbitals - min p occupation"^^xmls:string ;
	rdfs:comment "Minimum p occupation of antibonding orbitals"^^xmls:string ;
.

tmBp:antibond_energy_min_max_difference
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Antibonding orbitals - min-max difference"^^xmls:string ;
	rdfs:comment "Energy difference between lowest- and highest-energy antibonding orbitals"^^xmls:string ;
.