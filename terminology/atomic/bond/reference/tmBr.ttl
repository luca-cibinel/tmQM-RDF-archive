@prefix tmB: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/bond/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tmBr: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/bond/reference/> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

tmBr:NBOTypeBD
	rdf:type tmB:NBOType ;
	rdfs:label "NBO type - BD"^^xmls:string ;
	rdfs:comment "Localized bonding orbital in the framework of NBO theory"^^xmls:string ;
.

tmBr:NBOTypeNone
	rdf:type tmB:NBOType ;
	rdfs:label "NBO type - None"^^xmls:string ;
	rdfs:comment ""^^xmls:string ;
.