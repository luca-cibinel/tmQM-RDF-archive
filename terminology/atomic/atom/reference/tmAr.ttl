@prefix tmAr: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/atom/reference/> .
@prefix ms: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/misc/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

tmAr:Element
	rdf:type rdfs:Class ;
	rdfs:subClassOf ms:Countable ;
	rdfs:label "Chemical element"^^xmls:string ;
	rdfs:comment "This class represents a chemical element, intended as a label for an atom."^^xmls:string ;
.