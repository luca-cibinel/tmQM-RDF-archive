@prefix tmAr: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/atom/reference/> .
@prefix tmA: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/atom/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

tmA:Atom
	rdf:type rdfs:Class ;
	rdfs:label "Atom"^^xmls:string ;
	rdfs:comment "This class represents an atom."^^xmls:string ;
.

tmA:isAtom
	rdfs:subPropertyOf rdf:type ;
	rdfs:domain tmA:Atom ;
	rdfs:range tmAr:AtomClass ;
	rdfs:label "Is atom"^^xmls:string ;
	rdfs:comment "Specifies the class (element) of an atom."^^xmls:string ;
.