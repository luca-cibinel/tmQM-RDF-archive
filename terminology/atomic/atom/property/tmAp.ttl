@prefix ms: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/misc/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tmAp: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/atom/property/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

tmAp:x
	rdf:type rdfs:ContainerMembershipProperty ;
	rdfs:subPropertyOf rdf:_1 ;
	rdfs:domain ms:CartesianCoordinates3D ;
	rdfs:range xmls:float ;
	rdfs:label "X coordinate"^^xmls:string ;
	rdfs:comment "Specifies the cartesian x coordinate of an atom."^^xmls:string ;
.

tmAp:y
	rdf:type rdfs:ContainerMembershipProperty ;
	rdfs:subPropertyOf rdf:_2 ;
	rdfs:domain ms:CartesianCoordinates3D ;
	rdfs:range xmls:float ;
	rdfs:label "Y coordinate"^^xmls:string ;
	rdfs:comment "Specifies the cartesian y coordinate of an atom."^^xmls:string ;
.

tmAp:z
	rdf:type rdfs:ContainerMembershipProperty ;
	rdfs:subPropertyOf rdf:_3 ;
	rdfs:domain ms:CartesianCoordinates3D ;
	rdfs:range xmls:float ;
	rdfs:label "Z coordinate"^^xmls:string ;
	rdfs:comment "Specifies the cartesian z coordinate of an atom."^^xmls:string ;
.

tmAp:natural_electron_population_valence
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Natural electron population valence"^^xmls:string ;
	rdfs:comment "Electron occupation of valence orbitals"^^xmls:string ;
.

tmAp:natural_electron_configuration_p_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Natural electron configuration - p occupation"^^xmls:string ;
	rdfs:comment "Electron occupation of the p orbitals"^^xmls:string ;
.

tmAp:hydrogen_count
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Hydrogen count"^^xmls:string ;
	rdfs:comment "Number of hydrogen atoms bound to atomic node"^^xmls:string ;
.

tmAp:lone_vacancy_min_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone vacancy - min occupation"^^xmls:string ;
	rdfs:comment "Minimum occupation of lone vacancy orbitals"^^xmls:string ;
.

tmAp:lone_vacancy_min_energy
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone vacancy - min energy"^^xmls:string ;
	rdfs:comment "Minimum energy of lone vacancies"^^xmls:string ;
.

tmAp:lone_pair_max_energy
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone pair - max energy"^^xmls:string ;
	rdfs:comment "Maximum energy of lone pair orbitals"^^xmls:string ;
.

tmAp:lone_pair_max_d_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone pair - max d occupation"^^xmls:string ;
	rdfs:comment "Maximum d occupation of lone pair orbitals"^^xmls:string ;
.

tmAp:natural_electron_configuration_s_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Natural electron configuration - s occupation"^^xmls:string ;
	rdfs:comment "Electron occupation of the s orbitals"^^xmls:string ;
.

tmAp:lone_vacancy_min_s_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone vacancy - min s occupation"^^xmls:string ;
	rdfs:comment "Minimum s occupation of lone vacancy orbitals"^^xmls:string ;
.

tmAp:node_id
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Node ID"^^xmls:string ;
	rdfs:comment "A unique internal identifier used to distinguish the nodes of the atomic graph (i.e., the atoms)."^^xmls:string ;
.

tmAp:lone_vacancy_energy_min_max_difference
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone vacancy energy - min-max difference"^^xmls:string ;
	rdfs:comment "Energy difference between lowest- and highest-energy lone vacancy orbitals"^^xmls:string ;
.

tmAp:n_lone_pairs
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Number of lone pairs"^^xmls:string ;
	rdfs:comment "Number of lone pair orbitals"^^xmls:string ;
.

tmAp:lone_pair_max_p_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone pair - max p occupation"^^xmls:string ;
	rdfs:comment "Maximum p occupation of lone pair orbitals"^^xmls:string ;
.

tmAp:lone_pair_max_s_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone pair - max s occupation"^^xmls:string ;
	rdfs:comment "Maximum s occupation of lone pair orbitals"^^xmls:string ;
.

tmAp:lone_pair_energy_min_max_difference
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone pair energy - min-max difference"^^xmls:string ;
	rdfs:comment "Energy difference between lowest- and highest-energy lone pair orbitals"^^xmls:string ;
.

tmAp:lone_vacancy_min_d_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone vacancy - min d occupation"^^xmls:string ;
	rdfs:comment "Minimum d occupation of lone vacancy orbitals"^^xmls:string ;
.

tmAp:valency_index
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Valency index"^^xmls:string ;
	rdfs:comment "Valency index from NBO analysis"^^xmls:string ;
.

tmAp:natural_atomic_charge
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Natural atomic charge"^^xmls:string ;
	rdfs:comment "Natural atomic charge, in e units"^^xmls:string ;
.

tmAp:lone_pair_max_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone pair - max occupation"^^xmls:string ;
	rdfs:comment "Maximum electron occupation of the NBO lone pairs"^^xmls:string ;
.

tmAp:natural_electron_configuration_d_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Natural electron configuration - d occupation"^^xmls:string ;
	rdfs:comment "Electron occupation of the d orbitals"^^xmls:string ;
.

tmAp:node_position
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Node position"^^xmls:string ;
	rdfs:comment "Atom index in associated xyz geometry"^^xmls:string ;
.

tmAp:lone_vacancy_min_p_occupation
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lone vacancy - min p occupation"^^xmls:string ;
	rdfs:comment "Minimum p occupation of lone vacancy orbitals"^^xmls:string ;
.

tmAp:n_lone_vacancies
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Number of lone vacancies"^^xmls:string ;
	rdfs:comment "Number of lone vacancy orbitals"^^xmls:string ;
.