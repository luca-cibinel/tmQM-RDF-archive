.

cmTp:homo_lumo_gap_delta
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "HOMO-LUMO gap"^^xmls:string ;
	rdfs:comment "Change of HOMO-LUMO between different levels of theory"^^xmls:string ;
