@prefix ms: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/misc/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix cmTp: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/TMC/property/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .
@prefix cmT: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/complex/TMC/> .

cmTp:MetaDataDescription
	rdf:type rdfs:Class ;
	rdfs:label "Description of meta data"^^xmls:string ;
	rdfs:comment "This class represents an object whose purpose is to collect meta data about a TMC."^^xmls:string ;
.

cmTp:meta_data
	rdfs:domain cmT:TransitionMetalComplex ;
	rdfs:range cmTp:MetaDataDescription ;
	rdfs:label "Meta data"^^xmls:string ;
	rdfs:comment "Indicates the meta data associated with a given TMC."^^xmls:string ;
.

cmTp:enthalpy_energy
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Enthalpy energy"^^xmls:string ;
	rdfs:comment "Enthalpy energy"^^xmls:string ;
.

cmTp:electronic_energy
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Electronic energy"^^xmls:string ;
	rdfs:comment "Electronic energy"^^xmls:string ;
.

cmTp:charge
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Charge"^^xmls:string ;
	rdfs:comment "Overal charge of the metal complex"^^xmls:string ;
.

cmTp:lowest_vibrational_frequency
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Lowest vibrational frequency"^^xmls:string ;
	rdfs:comment "Lowest vibrational frequency in cm-1"^^xmls:string ;
.

cmTp:enthalpy_energy_correction
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Enthalpy energy correction"^^xmls:string ;
	rdfs:comment "Enthalpy energy correction"^^xmls:string ;
.

