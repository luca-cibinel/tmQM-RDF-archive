	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Molecular mass"^^xmls:string ;
	rdfs:comment "Molecular mass"^^xmls:string ;
.

cmTp:heat_capacity
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Heat capacity"^^xmls:string ;
	rdfs:comment "Heat capacity"^^xmls:string ;
.

cmTp:stoichiometry
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Stoichiometry"^^xmls:string ;
	rdfs:comment "Stoichiometry of the metal complex, in Hill format"^^xmls:string ;
.

cmTp:metal_center_period
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Periodic table period of the metal"^^xmls:string ;
	rdfs:comment "Periodic table period of the metal"^^xmls:string ;
.

cmTp:metal_center_group
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Periodic table group of the metal"^^xmls:string ;
	rdfs:comment "Periodic table group of the metal"^^xmls:string ;
.

cmTp:zpe_correction
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Zero-point energy"^^xmls:string ;
	rdfs:comment "Zero-point energy"^^xmls:string ;
.

cmTp:electronic_energy_delta
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Electronic energy gap"^^xmls:string ;
	rdfs:comment "Electronic energy difference between the different levels of theory"^^xmls:string ;
.

cmTp:polarisability
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Polarizability"^^xmls:string ;
	rdfs:comment "Overal polarizability of the metal complex"^^xmls:string ;
.

