@prefix lgL: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/ligand/> .
@prefix lgS: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/structure/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix lgB: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/bond/> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .
@prefix lgC: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/centre/> .

lgS:bLc
	rdfs:domain lgC:MetalCentre ;
	rdfs:range lgB:LigandBond ;
	rdfs:label "Chemical bond (ligand level)"^^xmls:string ;
	rdfs:comment "Indicates that a ligand level object participates in a chemical bond represented by the object	."^^xmls:string ;
.

lgS:bLl
	rdfs:domain lgL:Ligand ;
	rdfs:range lgB:LigandBond ;
	rdfs:label "Chemical bond (ligand level)"^^xmls:string ;
	rdfs:comment "Indicates that a ligand level object participates in a chemical bond represented by the object	."^^xmls:string ;
.