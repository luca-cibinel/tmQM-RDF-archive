@prefix lgCr: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/centre/reference/> .
@prefix tmA: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/atom/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .
@prefix lgC: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/centre/> .

lgC:MetalCentre
	rdf:type rdfs:Class ;
	rdfs:label "Metal centre"^^xmls:string ;
	rdfs:comment "This class represents a metal centre (intended as an abstract object that exists at the ligand level, and not as an atom)."^^xmls:string ;
.

lgC:isMetalCentre
	rdfs:subPropertyOf rdf:type ;
	rdfs:domain lgC:MetalCentre ;
	rdfs:range lgCr:MetalCentreClass ;
	rdfs:label "Is metal centre"^^xmls:string ;
	rdfs:comment "Specifies the class of a metal centre (intended as ligand level object)."^^xmls:string ;
.

lgC:hasAtom
	rdfs:domain lgC:MetalCentre ;
	rdfs:range tmA:Atom ;
	rdfs:label "Has atom"^^xmls:string ;
	rdfs:comment "Indicates the atom possessed by (i.e., that is) the metal centre (intended as ligand level object)	."^^xmls:string ;
.