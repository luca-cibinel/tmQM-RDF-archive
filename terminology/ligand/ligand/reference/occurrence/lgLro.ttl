@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix lgLro: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/ligand/reference/occurrence/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

lgLro:LigandOccurrenceClass
	rdf:type rdfs:Class ;
	rdfs:label "Ligand occurrence type"^^xmls:string ;
	rdfs:comment "This class represents the types of occurrences/representations of a ligand that can be encountered and used for computations (i.e., SMILES string, most stable occurrence, relaxed structure)."^^xmls:string ;
.