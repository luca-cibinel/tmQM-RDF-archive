@prefix lgLro: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/ligand/reference/occurrence/> .
@prefix ms: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/misc/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .
@prefix lgLrp: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/ligand/reference/property/> .

lgLrp:basedOn
	rdfs:domain ms:ObservedProperty ;
	rdfs:range lgLro:LigandOccurrenceClass ;
	rdfs:label "Based on occurrence"^^xmls:string ;
	rdfs:comment "Specifies the ligand representation on which a property is based on (SMILES, most stable occurrence or relaxed structure)."^^xmls:string ;
.

lgLrp:metal_bound_homo_energy
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "HOMO energy involving metal bound atom"^^xmls:string ;
	rdfs:comment "HOMO energy involving metal bound atom"^^xmls:string ;
.

lgLrp:sasa_area_free
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Ligand SASA area (free)"^^xmls:string ;
	rdfs:comment "Ligand SASA area (free)"^^xmls:string ;
.

lgLrp:charge
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "Charge"^^xmls:string ;
	rdfs:comment "Overal charge of the metal complex"^^xmls:string ;
.

lgLrp:metal_bound_lumo_p
	rdfs:subClassOf ms:ObservedProperty ;
	rdf:type ms:PropertyType ;
	rdfs:label "p orbital character of metal-bound LUMO"^^xmls:string ;
	rdfs:comment "p orbital character of metal-bound LUMO"^^xmls:string ;
.

