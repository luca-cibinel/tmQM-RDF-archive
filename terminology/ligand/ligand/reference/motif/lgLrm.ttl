@prefix lgLro: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/ligand/reference/occurrence/> .
@prefix lgLrm: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/ligand/reference/motif/> .
@prefix ms: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/misc/> .
@prefix lgLr: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/ligand/reference/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

lgLrm:StructuralFeature
	rdf:type rdfs:Class ;
	rdfs:subClassOf ms:Countable ;
	rdfs:label "Structural feature"^^xmls:string ;
	rdfs:comment "This class represents a structural feature of a ligand that can be counted."^^xmls:string ;
.

lgLrm:AliphaticRing
	rdf:type lgLr:StructuralFeature ;
	rdfs:label "Aliphatic ring"^^xmls:string ;
	rdfs:comment "This class represents a structural feature class identifiable as an aliphatic ring."^^xmls:string ;
.

lgLrm:AromaticRing
	rdf:type lgLr:StructuralFeature ;
	rdfs:label "Aromatic ring"^^xmls:string ;
	rdfs:comment "This class represents a structural feature class identifiable as an aromatic ring."^^xmls:string ;
.

lgLrm:SaturatedRing
	rdf:type lgLr:StructuralFeature ;
	rdfs:label "Saturated ring"^^xmls:string ;
	rdfs:comment "This class represents a structural feature class identifiable as a saturated ring."^^xmls:string ;
.

lgLrm:RotatableBond
	rdf:type lgLr:StructuralFeature ;
	rdfs:label "Rotatable bond"^^xmls:string ;
	rdfs:comment "This class represents a structural feature class identifiable as a rotatable bond."^^xmls:string ;
.

lgLrm:SMILES
	rdf:type lgLro:LigandOccurrenceClass ;
	rdfs:label "Occurrence - SMILES"^^xmls:string ;
	rdfs:comment "This class represents a ligand occurrence identified as the SMILES string."^^xmls:string ;
.

lgLrm:most_stable
	rdf:type lgLro:LigandOccurrenceClass ;
	rdfs:label "Occurrence - most stable"^^xmls:string ;
	rdfs:comment "This class represents a ligand occurrence identified as the most stable occurrence."^^xmls:string ;
.

lgLrm:relaxes_structure
	rdf:type lgLro:LigandOccurrenceClass ;
	rdfs:label "Occurrence - SMILES"^^xmls:string ;
	rdfs:comment "This class represents a ligand occurrence identified as the relaxed structure."^^xmls:string ;
.