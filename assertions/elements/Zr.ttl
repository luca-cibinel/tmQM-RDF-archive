@prefix tmAr: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/atom/reference/> .
@prefix ms: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/misc/> .
@prefix tmA: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/atom/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tmArp: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/atomic/atom/reference/property/> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .

tmAr:Zr
	rdfs:subClassOf tmA:Atom ;
	rdf:type tmAr:Element ;
	rdfs:label "Chemical element Zr (Zirconium)"^^xmls:string ;
	rdfs:comment "This class represents the chemical element Zr (Zirconium), intended as abstract representation of an atom with atomic number 40."^^xmls:string ;
	ms:hasProperty [
		rdf:type tmArp:atomic_number ;
		rdf:value "40"^^xmls:integer ;
	] ;
.