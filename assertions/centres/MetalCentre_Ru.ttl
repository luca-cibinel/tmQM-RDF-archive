@prefix lgCr: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/centre/reference/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xmls: <http://www.w3.org/2001/XMLSchema#> .
@prefix lgC: <https://www.integreat.no/research/rdf/tmqm-rdf-dataset/#/ligand/centre/> .

lgCr:MetalCentre_Ru
	rdfs:subClassOf lgC:MetalCentre ;
	rdf:type lgCr:MetalCentreClass ;
	rdfs:label "Metal centre Ru (Ruthenium)"^^xmls:string ;
	rdfs:comment "This class describes the metal centre Ru (Ruthenium), intended as an abstract object that exists at the ligand level, and not as an atom."^^xmls:string ;
.